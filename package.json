{
  "name": "beautiful-graph",
  "version": "2.0.0",
  "description": "Desktop knowledge graph with Obsidian-style physics and Beautiful Graph presentation.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build:wasm": "node tools/build-wasm.mjs",
    "build": "npm run build:wasm && tsc -noEmit -skipLibCheck && node esbuild.config.mjs production && node tools/verify-artifacts.mjs",
    "verify:artifacts": "node tools/verify-artifacts.mjs",
    "verify:phase8": "node tools/verify-phase8.mjs",
    "test:rust": "cargo test --locked --workspace",
    "pretest": "npm run build:wasm",
    "test": "node --experimental-strip-types --test tests/*.test.ts",
    "benchmark:check": "node --check tools/benchmark-harness.js"
  },
  "keywords": [
    "obsidian",
    "graph"
  ],
  "author": "Dawson Bodenhamer",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.15.17",
    "esbuild": "0.25.5",
    "obsidian": "latest",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@types/d3-force": "^3.0.10",
    "d3-force": "^3.0.0",
    "pixi.js": "^8.19.0"
  }
}
